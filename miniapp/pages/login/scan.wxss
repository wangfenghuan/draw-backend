/* pages/login/scan.wxss */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  padding: 40rpx;
}

.status-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  width: 90%;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.status-container.success {
  background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%);
}

.status-container.error {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
}

/* 加载动画 */
.loading-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 40rpx;
}

.spinner {
  width: 100%;
  height: 100%;
  border: 6rpx solid #e0e0e0;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 成功/错误图标 */
.success-icon,
.error-icon,
.info-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.success-icon {
  background-color: #4CAF50;
}

.error-icon {
  background-color: #f44336;
}

.info-icon {
  background-color: #4A90D9;
}

.success-icon .icon,
.error-icon .icon,
.info-icon .icon {
  font-size: 60rpx;
  color: #ffffff;
  font-weight: bold;
}

.info-icon .icon {
  font-size: 50rpx;
}

/* 文本样式 */
.status-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.status-container.success .status-text,
.status-container.error .status-text {
  color: #ffffff;
}

.status-desc {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 20rpx;
}

.status-container.success .status-desc,
.status-container.error .status-desc {
  color: rgba(255, 255, 255, 0.9);
}

.countdown {
  font-size: 32rpx;
  color: #ffffff;
  margin-top: 20rpx;
}

/* 手动输入 */
.manual-input {
  width: 100%;
  margin-top: 40rpx;
  padding-top: 40rpx;
  border-top: 1rpx solid #e0e0e0;
}

.input-label {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 16rpx;
}

.input-field {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.btn-primary {
  width: 100%;
  background-color: #4A90D9;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
}

.btn-primary:active {
  background-color: #3a7bc8;
}

.btn-secondary {
  width: 100%;
  background-color: #f5f5f5;
  color: #666666;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  margin-top: 20rpx;
}