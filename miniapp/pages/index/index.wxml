<!--pages/index/index.wxml-->
<view class="container">
  <view class="header">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <text class="title">DrawIO 在线绘图</text>
    <text class="subtitle">{{motto}}</text>
  </view>

  <view class="content">
    <view class="section">
      <text class="section-title">功能介绍</text>
      <view class="feature-list">
        <view class="feature-item">
          <text class="feature-icon">📊</text>
          <text class="feature-text">流程图绘制</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">🏗️</text>
          <text class="feature-text">架构图设计</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">🤖</text>
          <text class="feature-text">AI 智能生成</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">👥</text>
          <text class="feature-text">实时协作编辑</text>
        </view>
      </view>
    </view>

    <view class="section">
      <text class="section-title">扫码登录</text>
      <text class="section-desc">在 PC 端扫描二维码即可快速登录</text>
      <button class="btn-primary" bindtap="goToScanLogin">
        查看扫码登录
      </button>
    </view>
  </view>

  <view class="footer">
    <text class="copyright">© 2024 DrawIO. All rights reserved.</text>
  </view>
</view>